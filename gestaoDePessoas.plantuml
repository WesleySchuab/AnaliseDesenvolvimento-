@startuml InfoConstru - Gestão de Pessoas
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

actor "Analista de RH" as RH
actor "Gestor de Obra" as Gestor
actor "Colaborador" as Funcionario

rectangle "InfoConstru - Módulo Gestão de Pessoas" {
    
    package "Infraestrutura Base" {
        usecase "UC000 - Sincronizar Dados" as UC000
    }
    
    package "Cadastro e Departamento Pessoal" {
        usecase "UC001 - Cadastrar Colaborador" as UC001
        usecase "UC002 - Validar Documentação" as UC002
        usecase "UC003 - Gerenciar Contratos" as UC003
        
        ' Elemento de Decisão em formato Retangular
        rectangle "Documento\nAprovado?" as DecisaoDoc #FFAAAA
    }
    
    package "Ponto e Frentes de Trabalho" {
        usecase "UC004 - Apontar Horas" as UC004
        usecase "UC005 - Escalar Equipes" as UC005
        usecase "UC006 - Justificar Ausências" as UC006
        
        ' Elemento de Decisão em formato Retangular
        rectangle "Necessita\nBanco de Horas?" as DecisaoHoras #FFAAAA
    }
    
    package "Performance e Remuneração" {
        usecase "UC007 - Processar Folha" as UC007
        usecase "UC008 - Calcular Bônus" as UC008
        usecase "UC009 - Avaliar Desempenho" as UC009
    }
    
    ' Relacionamentos com fluxo de decisões
    UC001 <.. UC003 : <<extend>>
    
    UC002 ..> DecisaoDoc : <<valida>>
    DecisaoDoc ..> UC001 : <<no>> : (Bloqueia Alocação)
    
    UC004 ..> UC000 : <<include>>
    UC004 ..> DecisaoHoras : <<analisa>>
    DecisaoHoras ..> UC008 : <<yes>> : (Gera Adicional)
    
    UC007 ..> UC008 : <<include>>
}

' Relacionamentos estilo Entidade-Relacionamento (1 para N)
RH "1" --> "*" UC001
RH "1" --> "*" UC002
RH "1" --> "*" UC003
RH "1" --> "*" UC006
RH "1" --> "*" UC007

Gestor "1" --> "*" UC004
Gestor "1" --> "*" UC005
Gestor "1" --> "*" UC009

Funcionario "1" --> "*" UC004
Funcionario "1" --> "*" UC006

@enduml