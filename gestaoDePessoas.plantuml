@startuml InfoAgro - Gestão de Pessoas Atualizado
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

actor "Analista de RH" as RH
actor "Gestor de Campo" as Gestor
actor "Colaborador" as Funcionario

rectangle "InfoAgro - Módulo Gestão de Pessoas" {
    
    package "Infraestrutura Base" {
        usecase "UC000 - Sincronizar Dados em Modo Offline" as UC000
    }
    
    package "Cadastro e Departamento Pessoal" {
        usecase "UC001 - Manter Registro de Colaborador" as UC001
        usecase "UC002 - Controlar Documentação e Exames (NRs)" as UC002
        usecase "UC003 - Gerenciar Contratos de Safra" as UC003
    }
    
    package "Ponto e Frentes de Trabalho" {
        usecase "UC004 - Apontar Produção/Horas no Campo" as UC004
        usecase "UC005 - Escalar Frentes de Trabalho" as UC005
        usecase "UC006 - Justificar Ausências/Atestados" as UC006
    }
    
    package "Performance e Remuneração" {
        usecase "UC007 - Processar Folha de Pagamento" as UC007
        usecase "UC008 - Calcular Bônus por Produtividade" as UC008
        usecase "UC009 - Avaliar Desempenho Operacional" as UC009
    }
    
    ' Novas amarrações de requisitos
    UC001 <.. UC003 : <<extend>>
    UC007 ..> UC008 : <<include>>
    
    ' O apontamento agora depende da sincronização offline e alimenta a produtividade
    UC004 ..> UC000 : <<include>> : (Operação em Campo)
    UC004 ..> UC008 : <<evidences>> : (Vira base para bônus)
}

RH --> UC001
RH --> UC002
RH --> UC003
RH --> UC006
RH --> UC007

Gestor --> UC004 : (Informa Projeto/Centro de Custo obrigatório)
Gestor --> UC005
Gestor --> UC009

Funcionario --> UC004
Funcionario --> UC006

@enduml