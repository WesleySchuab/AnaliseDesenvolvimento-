@startuml InfoAgro - Gestão de Terceiros e EPIs
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

actor "Analista de Suprimentos / Almoxarifado" as Suprimentos
actor "Técnico de Segurança (SST)" as SST
actor "Fiscal de Contrato / Campo" as Fiscal
actor "Preposto / Gestor da Terceirizada" as Preposto

rectangle "InfoAgro - Módulo Gestão de Terceiros" {
    
    package "Homologação e Contratos" {
        usecase "UC101 - Homologar Empresa Terceirizada" as UC101
        usecase "UC102 - Gerenciar Contratos de Prestação de Serviço" as UC102
        usecase "UC103 - Auditar Certidões e Regularidade Fiscal" as UC103
    }
    
    package "Mobilização e Acesso" {
        usecase "UC104 - Cadastrar Trabalhadores Terceirizados" as UC104
        usecase "UC105 - Validar Integração e ASOs" as UC105
        usecase "UC106 - Controlar Acesso à Propriedade" as UC106
    }
    
    package "Gestão de EPIs (Segurança do Trabalho)" {
        usecase "UC110 - Controlar Estoque e Validade de CA dos EPIs" as UC110
        usecase "UC111 - Registrar Entrega/Ficha de EPI" as UC111
        usecase "UC112 - Fiscalizar Uso de EPI/EPC no Campo" as UC112
        usecase "UC113 - Registrar Substituição por Desgaste/Extravio" as UC113
    }
    
    package "Medição e Qualidade" {
        usecase "UC107 - Registrar Diário de Obra / Serviço" as UC107
        usecase "UC108 - Realizar Medição de Serviços" as UC108
        usecase "UC109 - Aplicar Penalidades / Advertências" as UC109
    }
    
    ' Relacionamentos
    UC101 ..> UC103 : <<include>>
    UC104 ..> UC105 : <<include>>
    UC105 ..> UC111 : <<include>> : (Exige Ficha de EPI Ativa)
    UC108 <.. UC109 : <<extend>> (Inconformidade de Segurança)
    UC112 <.. UC109 : <<extend>> (Trabalhador sem EPI)
    UC111 <.. UC113 : <<extend>>
}

' Associações dos Atores
Suprimentos --> UC101
Suprimentos --> UC102
Suprimentos --> UC108
Suprimentos --> UC110 : (Controle de Estoque)

SST --> UC105
SST --> UC110
SST --> UC111

Fiscal --> UC106
Fiscal --> UC107
Fiscal --> UC112 : (Blitz de Segurança)
Fiscal --> UC109

Preposto --> UC104
Preposto --> UC107
Preposto --> UC111 : (Fornece comprovante de entrega)

@enduml